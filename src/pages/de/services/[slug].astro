---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ServiceDetail from '../../../components/ServiceDetail.astro';
import { content } from '../../../data/site';

export function getStaticPaths() {
  return content.de.services.items.map((s) => ({
    params: { slug: s.slug },
    props: {
      slug: s.slug,
      title: `${s.title} | Salience Growth`,
      description: s.detail.tagline,
    },
  }));
}

const { slug, title, description } = Astro.props;
---

<Layout lang="de" title={title} description={description}>
  <Header lang="de" />
  <main>
    <ServiceDetail lang="de" slug={slug} />
  </main>
  <Footer lang="de" />
</Layout>
