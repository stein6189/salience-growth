---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { hero, proofStrip } = getContent(lang);
---

<section class="hero dark" id="top">
  <div class="glow" aria-hidden="true"></div>
  <div class="container inner">
    <p class="eyebrow eyebrow-light reveal">{hero.eyebrow}</p>

    <h1 class="title reveal">
      {hero.titlePre}<span class="hl">{hero.highlight}</span>{hero.titlePost}
    </h1>

    <p class="sub reveal">{hero.subtitle}</p>

    <div class="ctas reveal">
      <a href={hero.primaryCta.href} class="btn btn-primary">{hero.primaryCta.label}</a>
      <a href={hero.secondaryCta.href} class="btn btn-outline-light">{hero.secondaryCta.label}</a>
    </div>

    <p class="trust reveal">{hero.trustLine}</p>
  </div>

  <div class="container">
    <div class="proof reveal">
      {proofStrip.map((p) => (
        <div class="proof-item">
          <span class="proof-stat">{p.stat}</span>
          <span class="proof-label">{p.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(3.5rem, 8vw, 6rem);
    padding-bottom: 0;
  }
  .glow {
    position: absolute;
    top: -28%;
    right: -8%;
    width: 60vw;
    height: 60vw;
    max-width: 760px;
    max-height: 760px;
    background: radial-gradient(circle, rgba(226, 87, 30, 0.28), transparent 62%);
    filter: blur(10px);
    pointer-events: none;
  }
  .inner { position: relative; max-width: 900px; }

  .eyebrow-light { color: #f0a98c; }
  .eyebrow-light::before { background: var(--accent); }

  .title {
    margin-top: 1.5rem;
    font-size: clamp(2.6rem, 6.5vw, 5rem);
    letter-spacing: -0.035em;
    max-width: 16ch;
  }
  .hl {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.01em;
    color: #ffb98f;
  }

  .sub {
    margin-top: 1.75rem;
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    color: rgba(251, 249, 244, 0.78);
    max-width: 60ch;
    line-height: 1.55;
  }

  .ctas {
    margin-top: 2.25rem;
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .trust {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    color: rgba(251, 249, 244, 0.5);
  }

  .proof {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .proof-item {
    padding: 2rem 1.5rem 2.5rem;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
  }
  .proof-item:last-child { border-right: none; }
  .proof-stat {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.9rem);
    color: var(--paper);
    line-height: 1;
  }
  .proof-label {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.95rem;
    color: rgba(251, 249, 244, 0.65);
    max-width: 26ch;
  }

  @media (max-width: 720px) {
    .proof { grid-template-columns: 1fr; }
    .proof-item {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      padding: 1.5rem 0;
    }
    .proof-item:last-child { border-bottom: none; }
  }
</style>
