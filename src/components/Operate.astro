---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { operate } = getContent(lang);

type EngineItem = { n: string; title: string; body: string; foundation?: boolean };
const engines = operate.engines as EngineItem[];
const topEngines = engines.filter((e) => !e.foundation);
const foundation = engines.find((e) => e.foundation);
---

<section class="section operate" id="operate">
  <div class="container">
    <div class="head">
      <p class="eyebrow reveal">{operate.eyebrow}</p>
      <h2 class="section-title wide reveal">{operate.title}</h2>
      <p class="lead reveal">{operate.body}</p>
    </div>

    <div class="engines">
      {topEngines.map((e, i) => (
        <article class="engine reveal" style={`transition-delay:${i * 70}ms`}>
          <span class="n">{e.n}</span>
          <h3>{e.title}</h3>
          <p>{e.body}</p>
        </article>
      ))}
    </div>

    {foundation && (
      <article class="engine foundation dark reveal">
        <div class="foundation-meta">
          <span class="foundation-label">{operate.foundationLabel}</span>
          <span class="n">{foundation.n}</span>
        </div>
        <div class="foundation-content">
          <h3>{foundation.title}</h3>
          <p>{foundation.body}</p>
        </div>
      </article>
    )}

    <div class="cta reveal">
      <p>{operate.cta.lead}</p>
      <a class="btn btn-primary" href={operate.cta.href}>{operate.cta.label}</a>
    </div>
  </div>
</section>

<style>
  .section-title.wide { max-width: 24ch; }

  .engines {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
  }

  .engine {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
  }

  .n {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--accent-ink);
    line-height: 1;
  }

  .engine h3 {
    margin-top: 0.85rem;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .engine p {
    margin-top: 0.7rem;
    color: var(--muted);
    font-size: 0.93rem;
    line-height: 1.6;
  }

  /* Foundation card */
  .foundation {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 2.5rem;
    align-items: start;
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }

  .foundation-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.15rem;
  }

  .foundation-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(251, 249, 244, 0.5);
    white-space: nowrap;
  }

  .foundation .n { color: #ffb98f; }

  .foundation-content h3 {
    font-size: 1.35rem;
    color: var(--paper);
    margin-top: 0;
  }

  .foundation-content p {
    margin-top: 0.6rem;
    color: rgba(251, 249, 244, 0.75);
    font-size: 0.97rem;
  }

  .cta {
    margin-top: clamp(2.25rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius);
    background: var(--paper-2);
  }
  .cta p {
    font-size: clamp(1.05rem, 1.7vw, 1.2rem);
    max-width: 52ch;
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .engines { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .engines { grid-template-columns: 1fr; }
    .foundation { grid-template-columns: 1fr; gap: 1rem 0; }
  }
</style>
