---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { about } = getContent(lang);
const initials = about.founder.name.split(' ').map((w) => w[0]).join('');
---

<section class="section about" id="about">
  <div class="container">
    <div class="grid">
      <div class="text">
        <p class="eyebrow reveal">{about.eyebrow}</p>
        <h2 class="section-title reveal">{about.title}</h2>
        {about.body.map((para) => (
          <p class="para reveal">{para}</p>
        ))}
      </div>

      <aside class="founder reveal">
        <div class="avatar">
          <img
            class="photo"
            src={about.founder.photo}
            alt={`${about.founder.name}, ${about.founder.role} of Salience Growth`}
            onerror="this.parentElement.classList.add('no-photo'); this.remove();"
          />
          <span class="initials" aria-hidden="true">{initials}</span>
        </div>
        <h3>{about.founder.name}</h3>
        <span class="role">{about.founder.role}</span>
      </aside>
    </div>

    <div class="credibility">
      {about.credibility.map((c) => (
        <article class="cred reveal">
          <span class="dot" aria-hidden="true"></span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>

    <p class="punchline reveal">{about.punchline}</p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .para {
    margin-top: 1.25rem;
    color: var(--muted);
    font-size: 1.08rem;
    max-width: 56ch;
  }
  .founder {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
    position: sticky;
    top: 96px;
  }
  .avatar {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--ink);
  }
  .photo { width: 100%; height: 100%; object-fit: cover; }
  .avatar .initials {
    display: none;
    width: 100%;
    height: 100%;
    place-items: center;
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: 1.6rem;
  }
  .avatar.no-photo .initials { display: grid; }
  .founder h3 { margin-top: 1.1rem; font-size: 1.3rem; }
  .role {
    display: block;
    margin-top: 0.2rem;
    color: var(--accent-ink);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .credibility {
    margin-top: clamp(2.75rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .cred {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.6rem;
  }
  .cred .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .cred h3 { margin-top: 0.9rem; font-size: 1.2rem; }
  .cred p { margin-top: 0.6rem; color: var(--muted); font-size: 0.96rem; }

  .punchline {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    max-width: 60ch;
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.6vw, 1.9rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; }
    .founder { position: static; }
    .credibility { grid-template-columns: 1fr; }
  }
</style>
