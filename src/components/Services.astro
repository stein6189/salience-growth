---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { services } = getContent(lang);
---

<section class="section services" id="services">
  <div class="container">
    <div class="head">
      <p class="eyebrow reveal">{services.eyebrow}</p>
      <h2 class="section-title reveal">{services.title}</h2>
      <p class="lead reveal">{services.body}</p>
    </div>

    <div class="grid">
      {services.items.map((s, i) => (
        <article class="service reveal" style={`transition-delay:${(i % 3) * 70}ms`}>
          <div class="top">
            <h3>{s.title}</h3>
            <span class="dur">{s.duration}</span>
          </div>
          <p>{s.body}</p>
          <span class="arrow" aria-hidden="true">→</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .service {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.6rem;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .service:hover {
    border-color: var(--ink);
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px rgba(22, 24, 29, 0.4);
  }
  .top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .service h3 { font-size: 1.18rem; letter-spacing: -0.01em; }
  .dur {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-ink);
    background: var(--accent-soft);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .service p {
    margin-top: 0.85rem;
    color: var(--muted);
    font-size: 0.96rem;
  }
  .arrow {
    display: inline-block;
    margin-top: 1.1rem;
    color: var(--accent);
    font-size: 1.2rem;
    transition: transform 0.25s var(--ease);
  }
  .service:hover .arrow { transform: translateX(5px); }

  @media (max-width: 980px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 620px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
