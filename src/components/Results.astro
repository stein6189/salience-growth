---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { results } = getContent(lang);
---

<section class="section results" id="results">
  <div class="container">
    <p class="eyebrow reveal">{results.eyebrow}</p>
    <h2 class="section-title reveal">{results.title}</h2>

    <div class="hero-stat reveal">
      <span class="hs-stat">{results.hero.stat}</span>
      <span class="hs-label">{results.hero.label}</span>
      <span class="hs-note">{results.hero.note}</span>
    </div>

    <div class="benchmarks reveal">
      <div class="bm-head">
        <h3>{results.benchmarksHeading}</h3>
        <p>{results.benchmarksNote}</p>
      </div>
      <div class="metrics">
        {results.benchmarks.map((m, i) => (
          <div class="metric" style={`transition-delay:${i * 60}ms`}>
            <span class="stat">{m.stat}</span>
            <span class="label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="qual reveal">
      <div class="qual-stat">
        <span class="stat">{results.qualStat.stat}</span>
        <span class="label">{results.qualStat.label}</span>
      </div>
      <figure class="quote">
        <blockquote>"{results.qualCorroboration.quote}"</blockquote>
        <figcaption>
          <span class="role">{results.qualCorroboration.role}</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .hero-stat {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    border-radius: var(--radius);
    background: var(--ink);
    color: var(--paper);
  }
  .hs-stat {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 9vw, 6rem);
    line-height: 0.95;
    color: #ffb98f;
  }
  .hs-label {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 600;
    max-width: 22ch;
  }
  .hs-note {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(251, 249, 244, 0.55);
  }

  .benchmarks {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .bm-head { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .bm-head h3 {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .bm-head p { color: var(--muted); font-size: 0.88rem; }
  .metrics {
    margin-top: 1.75rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }
  .metric {
    border-left: 3px solid var(--accent);
    padding: 0.2rem 0 0.2rem 1rem;
  }
  .stat {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .label {
    display: block;
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .qual {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2.5rem;
    align-items: start;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius);
    background: var(--paper-2);
  }
  .qual-stat .stat {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--accent-ink);
  }
  .qual-stat .label {
    display: block;
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .quote {
    margin: 0;
    max-width: 64ch;
  }
  blockquote {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  figcaption {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
  }
  .name { font-weight: 600; }
  .role { color: var(--muted); font-size: 0.95rem; }

  @media (max-width: 900px) {
    .metrics { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .qual { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .metrics { grid-template-columns: 1fr; }
  }
</style>
