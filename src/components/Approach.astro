---
import { getContent } from '../data/site';
const { lang = 'en' } = Astro.props;
const { approach } = getContent(lang);
---

<section class="section dark approach" id="approach">
  <div class="container">
    <div class="head">
      <p class="eyebrow eyebrow-light reveal">{approach.eyebrow}</p>
      <h2 class="section-title reveal">{approach.title}</h2>
      <p class="lead reveal">{approach.body}</p>
    </div>

    <ol class="steps">
      {approach.steps.map((s) => (
        <li class="step reveal">
          <span class="n">{s.n}</span>
          <div class="body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .eyebrow-light { color: #f0a98c; }
  .eyebrow-light::before { background: var(--accent); }

  .steps {
    margin: clamp(2.5rem, 5vw, 4rem) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .step {
    position: relative;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }
  .step::after {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 38px;
    height: 2px;
    background: var(--accent);
  }
  .n {
    font-family: var(--font-serif);
    font-size: 2.6rem;
    color: rgba(251, 249, 244, 0.32);
    line-height: 1;
  }
  .step h3 {
    margin-top: 1rem;
    font-size: 1.35rem;
    color: var(--paper);
  }
  .step p {
    margin-top: 0.7rem;
    color: rgba(251, 249, 244, 0.7);
    font-size: 0.97rem;
  }

  @media (max-width: 900px) {
    .steps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .steps { grid-template-columns: 1fr; }
  }
</style>
